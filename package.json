{
  "name": "artisanal-hearth",
  "version": "1.0.0",
  "description": "The Artisanal Hearth — Full-stack café website",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "npx tailwindcss -i ./public/styles.css -o ./public/output.css --watch",
