  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "xss": "^1.0.15"
    "tailwindcss": "^3.4.19",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/container-queries": "^0.1.1"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "nodemon": "^3.1.4",
    "tailwindcss": "^3.4.19"
  }
