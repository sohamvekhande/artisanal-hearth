# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── JWT ──────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars

# ── Admin Credentials ────────────────────────────────
ADMIN_EMAIL=admin@artisanalhearth.in
# Generate bcrypt hash: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASS_HASH=$2a$12$your-bcrypt-hash-here

# ── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://artisanal-hearth.onrender.com
